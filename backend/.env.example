# Spring Boot
PORT=8080
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
APP_JWT_SECRET=replace-with-a-long-random-secret

# Railway MySQL
DB_URL=jdbc:mysql://<host>:<port>/<database>?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=<username>
DB_PASSWORD=<password>

# Optional
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
